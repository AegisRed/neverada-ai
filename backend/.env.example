# neverada.ai backend environment
# Copy this file to `.env` and adjust values.

# Server
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins.
# For local dev + GitHub Pages set both, e.g.:
# CORS_ORIGIN=http://localhost:5173,https://<username>.github.io
CORS_ORIGIN=*

# Data file (JSON persistence). Relative to backend/ root.
DATA_FILE=./data/db.json
